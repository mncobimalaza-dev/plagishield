# Copy this file's variable names into your hosting provider's
# "Environment Variables" settings. NEVER commit a real .env file to git.

# Your Anthropic API key (server-side only, from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A long, random secret used to sign session cookies.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# Upstash Redis (free tier) - used for user accounts + rate limiting.
# Create a database at https://console.upstash.com, then copy the REST
# credentials shown there.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: max Claude analyses per user per day (default 30)
ANALYZE_DAILY_LIMIT=30

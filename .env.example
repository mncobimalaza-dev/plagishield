# Copy this file's variable names into your hosting provider's
# "Environment Variables" settings. NEVER commit a real .env file to git.

# Your Anthropic API key (server-side only, from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A long, random secret used to sign session cookies.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# Upstash Redis (free tier) - used for user accounts + rate limiting.
# Create a database at https://console.upstash.com, then copy the REST
# credentials shown there.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: max Claude analyses per user per day (default 30)
ANALYZE_DAILY_LIMIT=30

# Resend (free tier) - used to send password reset emails.
# Sign up at resend.com, get your API key from the dashboard.
# NOTE: until you verify your own domain in Resend, the default sender can
# only deliver to the email address you signed up to Resend with.
RESEND_API_KEY=
EMAIL_FROM=PlagiShield <onboarding@resend.dev>

# Optional: your production URL, used to build password reset links.
# If unset, the app derives it from the incoming request automatically.
PUBLIC_BASE_URL=
